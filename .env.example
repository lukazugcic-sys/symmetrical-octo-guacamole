# Firebase configuration — copy to .env and fill in your values.
# Get these from: Firebase Console → Project Settings → Web app → SDK config.
#
# For local development:
#   cp .env.example .env
#
# For EAS builds (preview / production), add these as EAS secrets:
#   eas secret:create --scope project --name EXPO_PUBLIC_FIREBASE_API_KEY --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN --value "..."
#   ... (repeat for each key below)
#
# The app runs without Firebase (local SQLite saves only), but cloud sync,
# leaderboard and clan features will be disabled.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# AdMob rewarded ad unit IDs.
# For preview builds you can leave these empty and the app will fall back to
# Google's test rewarded unit. For production, use your real unit IDs.
EXPO_PUBLIC_ADMOB_REWARDED_ID=
EXPO_PUBLIC_ADMOB_REWARDED_ID_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_ID_IOS=
